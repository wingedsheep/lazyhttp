{
  "dev": {
    "api": "https://dummyjson.com",
    "bin": "https://httpbin.org",
    "user": "emilys",
    "pass": "emilyspass",
    "Security": {
      "Auth": {
        "demo": {
          "Type": "OAuth2",
          "Grant Type": "Client Credentials",
          "Token URL": "https://id.example.com/oauth/token",
          "Client ID": "demo-client",
          "Client Secret": "{{$processEnv OAUTH_CLIENT_SECRET}}",
          "Scope": "read",
          "Client Credentials": "basic"
        }
      }
    }
  },
  "local": {
    "api": "http://127.0.0.1:9000",
    "Security": {
      "Auth": {
        "demo": {
          "Type": "OAuth2",
          "Grant Type": "Client Credentials",
          "Token URL": "http://127.0.0.1:9000/token",
          "Client ID": "demo-client",
          "Client Secret": "demo-secret",
          "Scope": "read",
          "Client Credentials": "in body"
        },
        "browser": {
          "Type": "OAuth2",
          "Grant Type": "Authorization Code",
          "Auth URL": "http://127.0.0.1:9000/authorize",
          "Token URL": "http://127.0.0.1:9000/token",
          "Redirect URL": "http://127.0.0.1:8080/callback",
          "Client ID": "demo-client",
          "Scope": "openid",
          "Client Credentials": "none"
        }
      }
    }
  }
}
